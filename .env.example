# ─── Required ───────────────────────────────────────────────────────────────
# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port the server will listen on
PORT=3000

# ─── Optional ────────────────────────────────────────────────────────────────
# Directory where the SQLite cache database is stored (default: ./data)
# CACHE_DIR=./data

# Admin key for the cache-clearing endpoint at /api/admin/cache
# ADMIN_KEY=change-me

# GetSongBPM API key for BPM lookup (https://getsongbpm.com/api)
# Falls back to audio analysis if not set — leave blank if you don't have one
# GETSONGBPM_API_KEY=
