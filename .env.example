# ─── AI Provider ─────────────────────────────────────────────────────────────
#
# Option A — Google Gemini (FREE tier, recommended)
#   Get a free key at https://aistudio.google.com/apikey  (no credit card)
#   1,500 requests/day, no daily token limit
#
OPENAI_API_KEY=AIza...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-flash-latest
AI_MINI_MODEL=gemini-flash-lite-latest

#
# Option B — Groq (FREE tier, alternative)
#   Sign up at https://console.groq.com  →  API Keys  →  Create API Key
#   llama-3.1-8b-instant: 500,000 tokens/day (~60 generations)
#   llama-3.3-70b-versatile: 100,000 tokens/day (~12 generations)
#
# OPENAI_API_KEY=gsk_...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-8b-instant
# AI_MINI_MODEL=llama-3.1-8b-instant
#
# Option C — OpenAI (paid)
#   Requires billing at https://platform.openai.com
#
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4.1
# AI_MINI_MODEL=gpt-4.1-mini

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── YouTube Cookies (fixes "Sign in to confirm you're not a bot") ───────────
# 1. Install "Get cookies.txt LOCALLY" extension in Chrome (or "cookies.txt" in Firefox)
# 2. Go to youtube.com while logged in
# 3. Export cookies → save as cookies.txt in the project root (next to .env)
# The server auto-detects cookies.txt or youtube-cookies.txt on startup.

# ─── Optional ────────────────────────────────────────────────────────────────
# Directory where the SQLite cache database is stored (default: ./data)
# CACHE_DIR=./data

# Admin key for the cache-clearing endpoint at /api/admin/cache
# ADMIN_KEY=change-me

# GetSongBPM API key for BPM lookup (https://getsongbpm.com/api)
# Falls back to audio analysis if not set — leave blank if you don't have one
# GETSONGBPM_API_KEY=
