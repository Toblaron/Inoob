# ─── AI Provider ─────────────────────────────────────────────────────────────
#
# Option A — Groq (FREE tier, recommended for self-hosted / Raspberry Pi)
#   Sign up at https://console.groq.com  →  API Keys  →  Create API Key
#
# Two model tiers available on Groq free tier:
#
#   llama-3.1-8b-instant  →  500,000 tokens/day  (recommended — fast, ~60 generations/day)
#   llama-3.3-70b-versatile →  100,000 tokens/day  (richer output, ~12 generations/day)
#
OPENAI_API_KEY=gsk_...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
AI_MINI_MODEL=llama-3.1-8b-instant

# ↑ To switch to the higher-quality 70b model (uses 5× more of your daily quota):
# AI_MODEL=llama-3.3-70b-versatile
# AI_MINI_MODEL=llama-3.1-8b-instant   ← keep mini as 8b to preserve quota

#
# Option B — OpenAI (paid, requires billing at https://platform.openai.com)
#   Comment out the four Groq lines above, then set:
#
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4.1
# AI_MINI_MODEL=gpt-4.1-mini

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Optional ────────────────────────────────────────────────────────────────
# Directory where the SQLite cache database is stored (default: ./data)
# CACHE_DIR=./data

# Admin key for the cache-clearing endpoint at /api/admin/cache
# ADMIN_KEY=change-me

# GetSongBPM API key for BPM lookup (https://getsongbpm.com/api)
# Falls back to audio analysis if not set — leave blank if you don't have one
# GETSONGBPM_API_KEY=
